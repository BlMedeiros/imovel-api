type Query {
    searchPropertyById(id: ID!): Property
}

type CommercialProperty implements Property {
    id: ID!
    price: Float
    totalArea: Float
    localization: Localization!
    geographicPoint: GeographicPoint
    propertyStatus: PropertyStatus

    officeRooms: Int!
    bathrooms: Int!
    parkingSpots: Int!
    isStreetFront: Boolean!
}